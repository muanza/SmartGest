<?xml version="1.0" encoding="UTF-8"?>
<Context>
    <Resource name="jdbc/smartgest_master"
              auth="Container"
              type="javax.sql.DataSource"
              driverClassName="org.postgresql.Driver"
              url="jdbc:postgresql://localhost:5432/smartgest_master"
              username="smartgest"
              credential="smartgest"
              maxTotal="30"
              maxIdle="10"
              maxWaitMillis="10000" />
</Context>
